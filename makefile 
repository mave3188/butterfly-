        @echo -e "${CYAN}  в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${RESET}"
        @echo ""

        @echo -e "${BLUE}  [вҸі] Checking Internet Connection...${RESET}"
        @ping -c 1 8.8.8.8 > /dev/null 2>&1 || { echo -e "${RED}  [вңҳ] No internet! Skipping git pull.${RESET}"; sleep 1; }

        @echo -e "${BLUE}  [вҸі] Syncing with GitHub (Force Pull)...${RESET}"
        @git fetch --all 2>/dev/null || true
        @git reset --hard origin/main 2>/dev/null || echo -e "${YELLOW}  [вҡ ]  Not a git repo or no remote. Skipping.${RESET}"
        @echo -e "${GREEN}  [вң”] Repository synchronized!${RESET}"
        @echo ""

        @echo -e "${CYAN}  в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${RESET}"
