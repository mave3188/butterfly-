        @${PYTHON} ${TARGET}

clean:
        @clear
        @echo -e "${CYAN}"
        @echo "  в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
        @echo "  в•‘       рҹ§№  THE RIPPER - CLEANUP UTILITY                   в•‘"
        @echo "  в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ"
        @echo -e "${RESET}"
        @echo -e "${YELLOW}  [i] Removing temporary files...${RESET}"
        @rm -f Ripper.enc.py Ripper.bak.py 2>/dev/null || true
        @rm -rf __pycache__ 2>/dev/null || true
        @echo -e "${GREEN}  [вң”] Cleanup complete!${RESET}"

backup:
        @clear
        @echo -e "${CYAN}"
        @echo "  в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
        @echo "  в•‘       рҹ“Ұ  THE RIPPER - BACKUP UTILITY                    в•‘"
        @echo "  в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ"
        @echo -e "${RESET}"
        @if [ -f ${TARGET} ]; then \
                echo -e "${YELLOW}  [i] Backing up ${TARGET}...${RESET}"; \
                cp ${TARGET} Ripper.bak.py; \
                echo -e "${GREEN}  [вң”] Backup saved as Ripper.bak.py${RESET}"; \
        else \
                echo -e "${RED}  [вңҳ] Error: ${TARGET} not found!${RESET}"; \
        fi

all: clean backup run