run: ## рҹ”Ҙ Run the spammer
	@echo "${CYAN}в–¶ Starting Dark Shadow Spammer...${RESET}"
	@$(PYTHON) $(SCRIPT)

install: ## рҹ“Ұ Install dependencies
	@echo "${CYAN}в–¶ Installing required packages...${RESET}"
	@pip install $(REQUIREMENTS) --quiet
	@echo "${GREEN}вң“ All dependencies installed${RESET}"

update: ## рҹ”„ Update script from repository (if applicable)
	@echo "${CYAN}в–¶ Updating...${RESET}"
	@git pull 2>/dev/null || echo "${YELLOW}Not a git repository, skipping${RESET}"
	@echo "${GREEN}вң“ Updated${RESET}"

clean: ## рҹ§№ Clean cache and temporary files
	@echo "${CYAN}в–¶ Cleaning...${RESET}"
	@rm -rf __pycache__ *.pyc *.pyo 2>/dev/null || true
	@find . -name "*.pyc" -delete 2>/dev/null || true
	@echo "${GREEN}вң“ Cleaned${RESET}"

whitelist: ## рҹ”‘ Show current device ID and whitelist
	@echo "${CYAN}в–¶ Device Info...${RESET}"
	@echo "${BOLD}Device ID:${RESET} $$(whoami)@$$(hostname):$$(uname -m)"
	@echo ""
	@if [ -f $(WHITELIST) ]; then \
		echo "${BOLD}${GREEN}Allowed devices:${RESET}"; \
		cat $(WHITELIST) | sed 's/^/  в—Ҹ /'; \
	else \
		echo "${YELLOW}No whitelist file found.${RESET}"; \
	fi

reset: ## рҹ”„ Reset whitelist (add current device as owner)
	@echo "${CYAN}в–¶ Resetting whitelist...${RESET}"
	@echo "$$(whoami)@$$(hostname):$$(uname -m)" > $(WHITELIST)
	@chmod 600 $(WHITELIST)
	@echo "${GREEN}вң“ Current device added as owner${RESET}"

quick: ## вҡЎ Quick run (with no output, silent mode)
	@$(PYTHON) $(SCRIPT) > /dev/null 2>&1

status: ## рҹ“Ҡ Check script status
	@echo "${CYAN}в–¶ Status Check...${RESET}"
	@if [ -f $(SCRIPT) ]; then \
		echo "${GREEN}вң“ Script found: $(SCRIPT)${RESET}"; \
	else \
		echo "${RED}вң— Script not found: $(SCRIPT)${RESET}"; \
	fi
	@if command -v $(PYTHON) >/dev/null 2>&1; then \
		echo "${GREEN}вң“ Python3 found: $$($(PYTHON) --version)${RESET}"; \
	else \
		echo "${RED}вң— Python3 not found${RESET}"; \
	fi
	@if pip show $(REQUIREMENTS) >/dev/null 2>&1; then \
		echo "${GREEN}вң“ Dependency '$(REQUIREMENTS)' installed${RESET}"; \
	else \
		echo "${YELLOW}вҡ  Dependency '$(REQUIREMENTS)' not installed (run 'make install')${RESET}"; \
	fi

.PHONY: help run install update clean whitelist reset quick status