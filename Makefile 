	@rm -rf __pycache__ 2>/dev/null || true
	@echo -e "${GREEN}  [вң”] Cleanup complete!${RESET}"

backup:
	@clear
	@echo -e "${CYAN}"
	@echo "  рҹ“Ұ  DARK SHADOW - BACKUP"
	@echo -e "${RESET}"
	@if [ -f ${TARGET} ]; then \
		echo -e "${YELLOW}  [i] Backing up ${TARGET}...${RESET}"; \
		cp ${TARGET} Spammer.bak.py; \
		echo -e "${GREEN}  [вң”] Backup saved as Spammer.bak.py${RESET}"; \
	else \
		echo -e "${RED}  [вңҳ] Error: ${TARGET} not found!${RESET}"; \
	fi

